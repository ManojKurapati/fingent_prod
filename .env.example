# AI-Native Finance Platform — environment variables.
# Copy to `.env` (git-ignored) and fill in. NOTHING here is required to run the
# foundation locally today: the default app boots with in-memory fakes and a
# stub Claude transport. These become active as the production context lands.

# --- Claude API (planned) -------------------------------------------------
# Used by the production Anthropic transport for the ClaudeGateway. The default
# AppContext (app/api/context.py) ignores it and uses a no-network stub.
ANTHROPIC_API_KEY=

# --- Frontend (build-time, Vite) ------------------------------------------
# Base URL the React app calls. Leave empty to use relative paths (the nginx
# container / vite dev proxy forwards them to the backend).
VITE_API_URL=
# Backend the Vite dev server proxies to (local dev + Playwright e2e only).
VITE_PROXY_TARGET=http://127.0.0.1:8000

# --- Datastores (planned — target architecture, not yet wired) ------------
# DATABASE_URL=postgresql+asyncpg://finance:finance@db:5432/finance
# REDIS_URL=redis://redis:6379/0
# POSTGRES_PASSWORD=finance
